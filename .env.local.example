# ===== CONFIGURACIÓN PARA DESARROLLO =====
# Este archivo es un template. Copia a .env.local y reemplaza los valores

# WhatsApp Configuration (REEMPLAZA con tu número)
# Formato: código de país + número sin espacios
# Ejemplo: 549 3426 000000 → 5493426000000
NEXT_PUBLIC_WHATSAPP_PHONE=5493426000000
NEXT_PUBLIC_WHATSAPP_BUSINESS_NAME=Dra. María García

# Site Configuration (REEMPLAZA con tu dominio en producción)
# Desarrollo: http://localhost:3000
# Producción: https://tudominio.com
NEXT_PUBLIC_SITE_URL=http://localhost:3001
NEXT_PUBLIC_SITE_NAME=Psicóloga Clínica - Entre Ríos

# ===== NOTAS IMPORTANTES =====
# 1. Las variables con NEXT_PUBLIC_ son visibles en el cliente (incluidas en JS compilado)
# 2. NO comitees .env.local a Git - está en .gitignore
# 3. En Vercel: Settings → Environment Variables
# 4. Recuerda actualizar URLs cuando hagas deploy
